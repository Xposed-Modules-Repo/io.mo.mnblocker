    <!-- ===== Root-free mode (NotificationListenerService) ===== -->
    <string name="rootfree_service_label">营销通知拦截器（免 Root）</string>
    <string name="setup_title">选择拦截模式</string>
    <string name="setup_subtitle">两种模式二选一，随时可在设置页切换。</string>
    <string name="setup_root_title">Root 模式</string>
    <string name="setup_root_desc"><![CDATA[需要 Root 权限并安装 LSPosed，将本模块添加到 Xposed 作用域。
通知类别被拦截后完全静默，不会出现再消失。]]></string>
    <string name="setup_choose_root">选择 Root 模式</string>
    <string name="setup_rootfree_title">免 Root 模式</string>
    <string name="setup_rootfree_desc"><![CDATA[只需在系统设置中授予「通知使用权」，无需 Root / Magisk / KernelSU / LSPosed。
受系统限制，被拦截的通知会先短暂出现（可能有提示音）再被撤销；无法感知开启前就存在、之后未再触发的旧通知类别。]]></string>
    <string name="setup_choose_rootfree">选择免 Root 模式</string>

