<resources>
    <string name="app_name">营销通知拦截器</string>
    <string name="xposed_description">Hook 系统框架，自动识别并关闭包含「营销」等关键字的通知类别。支持正则与批量正则，内置安全模式与 Hook 日志。</string>

    <!-- Module is only meaningful inside the system framework -->
    <string-array name="xposed_scope">
        <item>android</item>
    </string-array>

    <!-- ===== AboutActivity ===== -->
    <string name="about_version_fmt">版本号 %1$s</string>
    <string name="about_description"><![CDATA[说明：
• 开关 ON = 拦截该类别通知，OFF = 允许。
• 手动开关属于单独覆盖，优先级高于正则。
• Hook 日志：%1$s/hook.log]]></string>
